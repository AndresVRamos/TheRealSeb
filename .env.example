# ============================================================================
#                    THE REAL SEB - CONFIGURACION
# ============================================================================
#
# INSTRUCCIONES:
# 1. Renombra este archivo a ".env" (sin las comillas)
# 2. Reemplaza los valores YOUR_..._HERE con tus credenciales
# 3. El TOKEN de Discord es OBLIGATORIO, el resto es opcional
#
# ============================================================================

# ============================================================================
# DISCORD BOT TOKEN (OBLIGATORIO)
# ============================================================================
# Como obtenerlo:
# 1. Ve a https://discord.com/developers/applications
# 2. Click en "New Application" y dale un nombre
# 3. En el menu lateral, click en "Bot"
# 4. Click en "Reset Token" y copia el token generado
# 5. IMPORTANTE: En "Privileged Gateway Intents", activa "Message Content Intent"
# 6. Para invitar el bot a tu servidor, ve a "OAuth2" > "URL Generator"
#    - Selecciona scope "bot" y permisos: Connect, Speak, Send Messages, etc.
#
discord_token=YOUR_DISCORD_BOT_TOKEN_HERE

# ============================================================================
# SPOTIFY API (OPCIONAL - para reproducir links de Spotify)
# ============================================================================
# Como obtenerlo:
# 1. Ve a https://developer.spotify.com/dashboard
# 2. Click en "Create app"
# 3. Llena el formulario (Redirect URI puede ser http://localhost:8888/callback)
# 4. Una vez creada, copia el Client ID y Client Secret
#
# Si no configuras esto, los links de Spotify no funcionaran
# pero la busqueda de YouTube seguira funcionando normalmente.
#
SPOTIPY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
SPOTIPY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET_HERE

# ============================================================================
# GENIUS API (OPCIONAL - para mejor cobertura de letras)
# ============================================================================
# Como obtenerlo:
# 1. Ve a https://genius.com/api-clients
# 2. Click en "Create an API Client"
# 3. Llena el formulario
# 4. Copia el "Client Access Token"
#
# Si no configuras esto, las letras se buscaran en LRCLib y lyrics.ovh
# que funcionan bien para la mayoria de canciones.
#
GENIUS_API_KEY=YOUR_GENIUS_API_KEY_HERE
