# Configuracion del Bot de Discord
discord_token=YOUR_DISCORD_BOT_TOKEN_HERE

# Configuracion de API de Spotify (opcional para soporte de Spotify)
SPOTIPY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
SPOTIPY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET_HERE

# Configuracion de Genius API (opcional para mejor cobertura de letras)
# Obtener en: https://genius.com/api-clients
GENIUS_API_KEY=YOUR_GENIUS_API_KEY_HERE
